  <property name="styleSheet">
   <string notr="true">
QPushButton#btn_HocTap, QPushButton#btn_DiChuyen, QPushButton#btn_AnUong {
    background-color: #2ecc71; color: white; border: none;
    border-radius: 6px; padding: 6px 12px; font-weight: bold;
}
QPushButton#btn_HocTap:hover, QPushButton#btn_DiChuyen:hover, QPushButton#btn_AnUong:hover {
    background-color: #27ae60;
}
QPushButton#btn_Luu {
    background-color: #27ae60; color: white; border: none;
    border-radius: 6px; padding: 8px; font-weight: bold;
}
QPushButton#btn_Loc {
    background-color: #16a085; color: white; border: none;
    border-radius: 6px; padding: 6px 16px; font-weight: bold;
}
QPushButton#btn_Loc:hover { background-color: #1abc9c; }
QPushButton#btn_XemTat {
    background-color: #7f8c8d; color: white; border: none;
    border-radius: 6px; padding: 6px 16px; font-weight: bold;
}
QPushButton#btn_XemTat:hover { background-color: #95a5a6; }
QPushButton#btn_DanAnh {
    background-color: #2980b9; color: white; border: none;
    border-radius: 6px; padding: 6px 14px; font-weight: bold;
}
QPushButton#btn_DanAnh:hover { background-color: #3498db; }
QLineEdit#txt_SoTien, QLineEdit#txt_GhiChu {
    border: 2px solid #2ecc71; border-radius: 6px;
    padding: 6px 10px; background-color: #ffffff;
}
QDateEdit#date_BatDau, QDateEdit#date_KetThuc {
    border: 2px solid #2ecc71; border-radius: 6px;
    padding: 4px 8px; background-color: #ffffff;
}
QLabel#lbl_TongTien {
    color: #1e8449; font-size: 15px; font-weight: bold;
    background-color: #d5f5e3; border: 2px solid #2ecc71;
    border-radius: 6px; padding: 6px 12px;
}
QLabel#lbl_AnhHoaDon {
    color: #2980b9; font-style: italic;
}
QTableWidget#table_GiaoDich QHeaderView::section {
    background-color: #27ae60; color: white;
    font-weight: bold; padding: 6px; border: none;
}
QMenuBar { background-color: #1e8449; color: white; }
QStatusBar { background-color: #d5f5e3; color: #1e8449; }
